{
  "name": "database-nexus-vscode",
  "displayName": "Database Nexus Replicator",
  "description": "Extension de VS Code para trabajar con la skill, plugin y flujo de replicacion de Database Nexus.",
  "version": "0.2.0",
  "publisher": "victorplatero",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/UPT-FAING-EPIS/proyecto-si783-2026-i-u3-replicador_de_datos_entre_base_de_datos.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "files": [
    "extension.js",
    "fileAnalysis.js",
    "flowTemplate.js",
    "README.md",
    "LICENSE",
    "samples/**"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:databaseNexus.openSkill",
    "onCommand:databaseNexus.openPlugin",
    "onCommand:databaseNexus.openChatbox",
    "onCommand:databaseNexus.insertPrompt",
    "onCommand:databaseNexus.validateAssistant",
    "onCommand:databaseNexus.openLocalApp",
    "onCommand:databaseNexus.createFlow",
    "onCommand:databaseNexus.analyzeDatabaseFile"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "databaseNexus.openSkill",
        "title": "Database Nexus: Abrir skill del asistente"
      },
      {
        "command": "databaseNexus.openPlugin",
        "title": "Database Nexus: Abrir plugin del asistente"
      },
      {
        "command": "databaseNexus.openChatbox",
        "title": "Database Nexus: Abrir chatbox integrado"
      },
      {
        "command": "databaseNexus.insertPrompt",
        "title": "Database Nexus: Insertar consulta sugerida"
      },
      {
        "command": "databaseNexus.validateAssistant",
        "title": "Database Nexus: Validar skill, plugin y chatbox"
      },
      {
        "command": "databaseNexus.openLocalApp",
        "title": "Database Nexus: Abrir app local"
      },
      {
        "command": "databaseNexus.createFlow",
        "title": "Database Nexus: Crear flujo de replicacion"
      },
      {
        "command": "databaseNexus.analyzeDatabaseFile",
        "title": "Database Nexus: Analizar archivo de datos"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "databaseNexus.analyzeDatabaseFile",
          "when": "resourceExtname == .sqlite || resourceExtname == .sqlite3 || resourceExtname == .db || resourceExtname == .csv || resourceExtname == .xlsx || resourceExtname == .json || resourceExtname == .ndjson || resourceExtname == .sql",
          "group": "navigation@19"
        },
        {
          "command": "databaseNexus.validateAssistant",
          "group": "navigation@20"
        }
      ],
      "commandPalette": [
        {
          "command": "databaseNexus.openSkill"
        },
        {
          "command": "databaseNexus.openPlugin"
        },
        {
          "command": "databaseNexus.openChatbox"
        },
        {
          "command": "databaseNexus.insertPrompt"
        },
        {
          "command": "databaseNexus.validateAssistant"
        },
        {
          "command": "databaseNexus.openLocalApp"
        },
        {
          "command": "databaseNexus.createFlow"
        },
        {
          "command": "databaseNexus.analyzeDatabaseFile"
        }
      ]
    }
  }
}
